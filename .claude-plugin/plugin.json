{
  "name": "claude-code-status",
  "version": "0.1.0",
  "description": "Displays counts from external services (week/session usage, gmail, tasks, jira, github) in Claude Code's status line.",
  "author": {
    "name": "USER"
  },
  "keywords": ["statusline", "gmail", "tasks", "jira", "github", "productivity"],
  "skills": "./skills/",
  "hooks": {
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "${CLAUDE_PLUGIN_ROOT}/hooks/session-start.sh"
          }
        ]
      }
    ]
  }
}
