{
  "name": "claude-status-runtime",
  "version": "0.1.0",
  "description": "Runtime renderer for claude-status Claude Code plugin",
  "main": "dist/render.js",
  "scripts": {
    "build": "tsc --project tsconfig.json",
    "build:watch": "tsc --project tsconfig.json --watch",
    "start": "node dist/render.js",
    "clean": "rimraf dist",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "devDependencies": {
    "@types/node": "^20.19.37",
    "rimraf": "^5.0.5",
    "typescript": "^5.4.5",
    "vitest": "^4.1.1"
  }
}
